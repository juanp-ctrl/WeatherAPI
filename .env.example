# ── Shared ───────────────────────────────────────────────────────────────────
API_KEY=change-me-in-production
LOG_LEVEL=INFO
DATABASE_POOL_SIZE=5
DATABASE_MAX_OVERFLOW=5

# ── ingestion-service ────────────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://weather:weather@localhost:5432/weather_middleware
INGESTION_SCHEMA=ingestion
OPEN_METEO_BASE_URL=https://api.open-meteo.com
INGESTION_INTERVAL_SECONDS=900

# ── processing-service ───────────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://weather:weather@localhost:5432/weather_middleware
PROCESSING_SCHEMA=processing
INGESTION_SERVICE_URL=http://localhost:8000
PROCESSING_INTERVAL_SECONDS=300
